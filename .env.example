ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.kimi.com/coding/
ANTHROPIC_DEFAULT_HAIKU_MODEL=kimi-for-coding
ANTHROPIC_DEFAULT_OPUS_MODEL=kimi-for-coding
ANTHROPIC_DEFAULT_SONNET_MODEL=kimi-for-coding
ANTHROPIC_MODEL=kimi-for-coding
ANTHROPIC_REASONING_MODEL=kimi-for-coding
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# WeCom AI Bot Configuration
# Add your WeCom Bot credentials here:
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# Bot name in WeCom (for @mention detection in group chats)
WECOM_BOT_NAME=Nanoclaw

# Hide tool call process in WeCom messages (true/false)
WECOM_HIDE_TOOL_CALLS=true

# Enable streaming message updates in WeCom (true/false)
WECOM_STREAMING_ENABLED=true

# Show thinking indicator in WeCom (true/false)
WECOM_SHOW_THINKING=true
